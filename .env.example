# ── Local (npm run start:dev) ───────────────────────────────────────────────
PORT=3000
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/acrobit?retryWrites=true&w=majority
CORS_ORIGIN=http://localhost:4200

# Firebase Admin — local: ruta al JSON (gitignored en src/firebase/)
FIREBASE_PROJECT_ID=acrobit-app
GOOGLE_APPLICATION_CREDENTIALS=./src/firebase/tu-service-account.json

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=6000

# ── Vercel (Environment Variables — NO commitear) ─────────────────────────
# MONGODB_URI=          (misma URI Atlas; Network Access: 0.0.0.0/0)
# CORS_ORIGIN=          https://tu-front.vercel.app  (varias: url1,url2)
# FIREBASE_PROJECT_ID=  acrobit-app
# FIREBASE_SERVICE_ACCOUNT_JSON=  pegar JSON completo del service account en UNA línea
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_OUTPUT_TOKENS=6000
# NO uses GOOGLE_APPLICATION_CREDENTIALS en Vercel — usa FIREBASE_SERVICE_ACCOUNT_JSON
